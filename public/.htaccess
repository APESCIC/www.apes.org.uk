DirectoryIndex index.html index.php
Options -Indexes

RewriteEngine On

# Normalise beta-host traffic onto the production canonical host.
RewriteCond %{HTTP_HOST} ^beta\.apes\.org\.uk$ [NC]
RewriteRule ^ https://www.apes.org.uk%{REQUEST_URI} [R=301,L]

# Keep the public document root focused on rendered pages only.
RewriteRule ^includes/ - [F,L]
RewriteRule ^outputs/ - [F,L]
RewriteRule ^scripts/ - [F,L]

# Normalise the old /index route to the homepage.
RewriteRule ^index/?$ / [R=301,L]

# Legacy mission aliases still seen on the live site.
RewriteRule ^missions/our-main-mission-statement/?$ /mission/our-main-mission-statement/ [R=301,L]
RewriteRule ^missions/support-ethical-rehabilitation/?$ /mission/support-ethical-rehabilitation/ [R=301,L]

# Legacy short changelog aliases.
RewriteRule ^changelog/?$ /change-log-hub/ [R=301,L]
RewriteRule ^change-log/?$ /change-log-hub/ [R=301,L]

# Legacy main-site news routes now resolve through APES Newsroom successor pages.
RewriteRule ^news/post/Introducing-the-new-APES-CareBase/?$ https://www.apesnews.org.uk/introducing-the-new-myapes-manage-your-details-online/ [R=301,L]
RewriteRule ^news/post/Urgent-APES-Must-Relocate-by-3-March-2026/?$ https://www.apesnews.org.uk/tag/apes-cic/ [R=301,L]
RewriteRule ^news/post/APES-Partners-with-Double-the-Donation-to-Double-Your-Donation-Impact/?$ https://www.apesnews.org.uk/tag/apes-donor-community/ [R=301,L]
RewriteRule ^news/post/important-update-temporary-move-what-it-means-for-you/?$ https://www.apesnews.org.uk/tag/apes-cic/ [R=301,L]
RewriteRule ^news/post/fundraising-appeal-help-apes-invest-in-essential-welfare-management-software/?$ https://www.apesnews.org.uk/tag/apes-donor-community/ [R=301,L]
RewriteRule ^news/tag/moving-properties/?$ https://www.apesnews.org.uk/tag/apes-cic/ [R=301,L]
RewriteRule ^news/tag/funds/?$ https://www.apesnews.org.uk/tag/apes-donor-community/ [R=301,L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

ErrorDocument 403 /403.html
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html
